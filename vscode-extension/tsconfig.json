{
  "compilerOptions": {
    "module": "Node16",
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node", "vscode"],
    "outDir": "out",
    "rootDir": "src",
    "strict": true,
    "noEmitOnError": true,
    "skipLibCheck": true,
    "moduleResolution": "Node16",
    "sourceMap": true
  },
  "include": ["src/**/*"]
}
